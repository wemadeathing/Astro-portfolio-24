---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';

const expertise = [
  {
    title: 'AI-Powered Design & Product Development',
    description: `I build AI systems end to end — multi-agent architectures, RAG pipelines, agentic workflows, and the interfaces that sit on top of them. Stack: LangGraph, FastAPI, Supabase, OpenRouter, React, Astro. Recent: Kota AI (multi-agent SME platform), RideNote (iOS/Android, App Store live).`,
    icon: 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5',
  },
  {
    title: 'AI Training & Consulting',
    description: `I run workshops and advisory sessions on practical AI adoption and governance. ISO 42001 Lead Auditor certified. I have trained 30 to 40 people across corporate and professional cohorts. Sessions cover real tools, real workflows, and the governance questions that matter when AI is going into production.`,
    icon: 'M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z',
  },
  {
    title: 'End-to-End Product Design',
    description: `15 years designing digital products across financial services, retail, property, and tech. I can take a product from zero to deployed, or come in at any stage to shape and ship.`,
    icon: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z',
  },
  {
    title: 'Design & Web Development',
    description: `Design brand identities, marketing materials, and responsive websites. Build and ship custom sites using AstroJS, Webflow, Framer, WordPress, and HTML/CSS/JavaScript.`,
    icon: 'M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zM23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75',
  },
];

const skills = [
  {
    title: 'Product Design & Execution',
    items: [
      'UI/UX design for web and mobile',
      'Brand identity development',
      'Design system creation',
      'High-fidelity prototyping',
      'Responsive web design',
      'End-to-end product design (research to launch)',
    ],
  },
  {
    title: 'AI Systems & Architecture',
    items: [
      'LangGraph',
      'multi-agent orchestration',
      'RAG',
      'vector search',
      'MCP',
      'tool calling',
      'agentic workflows',
      'FastAPI',
      'OpenRouter',
      'Claude API',
      'prompt engineering',
      'structured output',
      'LangSmith',
      'PostHog',
    ],
  },
  {
    title: 'Technical Implementation',
    items: [
      'React',
      'AstroJS',
      'HTML/CSS',
      'PostgreSQL',
      'WordPress',
      'API Integration',
      'Third-party API integration and data scraping',
      'Cross-functional collaboration with dev teams',
    ],
  },
  {
    title: 'Design Tools',
    items: ['Figma', 'Adobe Creative Suite (Photoshop, Illustrator, InDesign)', 'Affinity', 'Canva'],
  },
  {
    title: 'AI Tools & Platforms',
    items: [
      'Claude AI',
      'Mistral',
      'Cursor',
      'OpenAI Integration',
      'Perplexity',
      'Replit',
      'Lovable',
      'Bolt',
      'Claude Code',
      'Warp',
      'Gamma',
    ],
  },
  {
    title: 'Collaboration & Workflow',
    items: [
      'Git/GitHub',
      'Agile/Scrum',
      'Developer Handoff',
      'Cross-functional collaboration',
      'User Research',
      'Usability Testing',
    ],
  },
];

const industry = [
  {
    title: 'Financial Services',
    items: ['ABSA', 'Bidvest Bank', 'Old Mutual', 'Standard Bank'],
  },
  {
    title: 'Retail & Consumer',
    items: ['Clicks', 'Musica', 'PEP', 'Shoprite', 'Checkers', "Sportsman's Warehouse"],
  },
  {
    title: 'Property & Real Estate',
    items: ['Rabie Property Group', 'Signatûra'],
  },
  {
    title: 'Technology & SaaS',
    items: ['EverPrompt', 'FindMeACoffee', 'Micro apps'],
  },
  {
    title: 'Small Business',
    items: ['Travel', 'Hospitality', 'Events', 'FMCG', 'Services'],
  },
];

const experience = [
  {
    role: 'AI Systems Designer & Builder',
    company: 'Independent',
    period: '2025 - Present',
    description: `Building Kota AI — a production multi-agent operations platform for SA SMEs using LangGraph, FastAPI, Supabase, and OpenRouter. Designed the full system architecture: Router and Workflow agents, RAG knowledge base, Generative UI response contract, multi-tenant RLS. Also shipping RideNote (iOS App Store live, Android in testing) and running AI governance workshops and advisory for organisations adopting AI.`,
  },
  {
    role: 'Lead Designer',
    company: 'Immersion Group',
    period: '2022 - 2024 | Remote',
    description: `Banking suite development across mobile, web, and dashboard. Led design system creation spanning three product streams. Delivered rapid innovation projects for Old Mutual and ABSA using FlutterFlow and Supabase. Initiated and led internal innovation program with cross-functional team of 6 throughout 2024.`,
  },
  {
    role: 'Senior Web Designer',
    company: 'Machete Creative',
    period: '2019 - 2022 | Cape Town',
    description: `Brand identity design from concept to completion, WordPress development and customization, responsive web design for multi-property real estate portfolio. Collaborated directly with development teams on website solutions and digital assets.`,
  },
  {
    role: 'Freelance Designer',
    company: 'Self-employed',
    period: '2014 - 2018',
    description: `Brand identity, digital design, and marketing collateral for clients across travel, hospitality, events, FMCG, and service industries. Built responsive websites and handled end-to-end design projects.`,
  },
  {
    role: 'Senior Graphic Designer',
    company: 'Musica & Clicks',
    period: '2009 - 2012',
    description: `In-house design for retail marketing materials, promotional campaigns, and brand assets across multiple product lines.`,
  },
];
---

<Layout
  title="About | Design Engineer · AI Systems, Skills & Governance"
  description="Design Engineer with 15+ years across design, product, and AI systems. Building Kota AI, ISO 42001 Lead Auditor certified, and helping organisations govern AI responsibly."
>
  <!-- Hero (wider / near full-width) -->
  <section class="py-10 sm:py-14">
    <!-- Match gutters with the main page container -->
    <div class="container max-w-[1100px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-8 sm:gap-10 items-center">
        <div class="max-w-[68ch]">
          <h1 class="text-4xl sm:text-5xl md:text-[54px] font-medium tracking-[-0.03em] leading-[1.05] text-white/95">
            Design Engineer · AI Systems, Skills & Governance
          </h1>
          <div class="mt-4 text-xs tracking-[0.22em] uppercase text-white/55">
            15+ years • AI systems design • Governance & ISO 42001 · Builder
          </div>
      <p class="mt-5 type-lead text-white/80">
            15 years across brand, product, and engineering — working with organisations in financial services, retail, property, and tech. Design is my foundation. It shapes how I approach every problem before anything else gets built.
          </p>
          <p class="mt-4 type-lead text-white/80">
            For the past three years AI has been the main focus. I build agentic systems, design the knowledge architecture underneath them, and think seriously about what responsible use actually looks like in practice. I got ISO 42001 Lead Auditor certified because most AI conversations are about capability, not risk. That thinking now shapes everything I build.
          </p>
          <p class="mt-4 type-lead text-white/80">
            I work across the full stack, solo. Design to deployment.
          </p>

        </div>

        <!-- Right-side visual (desktop) -->
        <div class="hidden lg:flex justify-end self-center">
          <img
            src="/images/NS-profile-2.png"
            alt="Nasif Salaam"
            class="w-full max-w-[240px] aspect-square object-cover rounded-3xl"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <div class="h-px bg-white/10"></div>

  <div class="container max-w-[1100px] mx-auto px-4 sm:px-6 lg:px-8">

    <!-- What I do -->
    <section id="now" class="py-12 sm:py-14 scroll-mt-28">
      <div class="flex items-end justify-between gap-6 mb-8">
        <div>
          <div class="text-xs tracking-[0.22em] uppercase text-white/50 mb-3">Now</div>
          <h2 class="type-h2 text-white/90">What I do</h2>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10 stagger-children">
        {expertise.map((item) => (
          <div class="max-w-[56ch]">
            <div class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5 text-primary"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d={item.icon} />
              </svg>
            </div>
            <h3 class="mt-4 text-lg sm:text-xl font-semibold text-white/92">{item.title}</h3>
            <p class="mt-2 text-sm sm:text-base leading-[1.65] text-white/80">
              {item.description}
            </p>
          </div>
        ))}
      </div>
    </section>

    <div class="h-px bg-white/10"></div>

    <!-- Skills -->
    <section id="capabilities" class="py-12 sm:py-14 scroll-mt-28">
      <div class="text-xs tracking-[0.22em] uppercase text-white/50 mb-3">Capabilities</div>
      <h2 class="type-h2 text-white/90">Skills</h2>

      <div class="mt-8 rounded-2xl border border-white/10 bg-white/[0.03] p-6 sm:p-7">
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 stagger-children">
          {skills.map((group) => (
            <div>
              <div class="text-sm font-semibold text-white/85 mb-3">{group.title}</div>
              <p class="text-sm text-white/70 leading-[1.75]">
                {group.items.join(' • ')}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="h-px bg-white/10"></div>

    <!-- Certifications -->
    <section id="certifications" class="py-12 sm:py-14 scroll-mt-28">
      <div class="text-xs tracking-[0.22em] uppercase text-white/50 mb-3">Certifications</div>
      <h2 class="type-h2 text-white/90">Credentials</h2>

      <div class="mt-8 rounded-2xl border border-white/10 bg-white/[0.03] p-6 sm:p-7">
        <div class="space-y-4 stagger-children">
          {[
            { name: 'ISO/IEC 42001:2023 Lead Auditor', issuer: 'Mastermind Assurance', year: '2026' },
            { name: 'Claude Certified Architect — Foundations', issuer: 'Anthropic', year: 'In progress' },
            { name: 'AI Security & Governance', issuer: 'Securiti', year: '2025' },
            { name: 'AI Fluency', issuer: 'Anthropic', year: '2025' },
            { name: 'Introduction to Generative AI', issuer: 'Google Cloud', year: '2024' },
          ].map((cert) => (
            <div class="flex items-start justify-between gap-4">
              <div>
                <div class="text-sm font-semibold text-white/85">{cert.name}</div>
                <div class="text-xs text-white/50 mt-0.5">{cert.issuer}</div>
              </div>
              <div class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-white/55 shrink-0">
                {cert.year}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="h-px bg-white/10"></div>

    <!-- Industry experience -->
    <section id="industry" class="py-12 sm:py-14 scroll-mt-28">
      <div class="text-xs tracking-[0.22em] uppercase text-white/50 mb-3">Industry experience</div>

      <div class="mt-8 rounded-2xl border border-white/10 bg-white/[0.03] p-6 sm:p-7">
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 stagger-children">
          {industry.map((group) => (
            <div>
              <div class="text-sm font-semibold text-white/85 mb-3">{group.title}</div>
              <p class="text-sm text-white/70 leading-[1.75]">
                {group.items.join(', ')}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="h-px bg-white/10"></div>

    <!-- Experience -->
    <section id="career" class="py-12 sm:py-14 scroll-mt-28">
      <div class="text-xs tracking-[0.22em] uppercase text-white/50 mb-3">Career</div>
      <h2 class="type-h2 text-white/90">Professional journey</h2>

      <div class="mt-8 space-y-3 stagger-children">
        {experience.map((item) => (
          <details class="group rounded-2xl border border-white/10 bg-white/[0.03] px-6 py-5 transition-colors hover:bg-white/[0.05] hover:border-white/20">
            <summary class="cursor-pointer select-none list-none focus:outline-none">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="text-lg font-semibold text-white/92">{item.role}</h3>
                  {item.company && <p class="text-sm text-white/65 mt-1">{item.company}</p>}
                </div>
                <div class="flex items-center gap-3 shrink-0">
                  <div class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-white/65">
                    {item.period}
                  </div>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="w-4 h-4 text-white/60 transition-transform duration-200 group-open:rotate-90"
                    aria-hidden="true"
                  >
                    <path d="M9 18l6-6-6-6"></path>
                  </svg>
                </div>
              </div>
              <div class="mt-3 text-xs text-white/45 group-open:hidden">Click to expand</div>
            </summary>
            <div class="pt-4">
              <div class="h-px bg-white/10"></div>
              <p class="mt-4 text-sm sm:text-base leading-[1.65] text-white/70">{item.description}</p>
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="pb-14 sm:pb-20">
      <div class="rounded-3xl border border-white/10 bg-[#121212]/70 backdrop-blur-xl p-8 sm:p-10">
        <div class="max-w-[72ch]">
          <h2 class="type-h2 text-white/92">
            Let’s build something useful.
          </h2>
          <p class="mt-3 text-base sm:text-lg leading-[1.65] text-white/80">
            If you're looking for a designer who can take ideas from concept to working product, let's connect.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <Button href="/contact" text="Let's Connect" variant="primary" />
            <a 
              href="/Nasif-Salaam-Resume.pdf" 
              download
              class="inline-flex h-12 items-center justify-center rounded-full border border-white/15 bg-white/5 px-6 text-sm font-semibold text-white/85 transition-colors hover:bg-white/10 hover:text-white focus:outline-none focus-visible:ring-4 focus-visible:ring-primary/20"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
              Download Resume
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>