---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';

const calLink = 'https://calendly.com/salaam-nasif/30min';
const emailAddress = 'hello@nasifsalaam.com';
---

<Layout
  title="AI Training | Nasif Salaam — Practical AI Workshops for Teams"
  description="Hands-on AI workshops that teach teams how to use Claude, ChatGPT, and other AI tools in their actual day-to-day work. Half-day sessions, custom for your industry."
  image="/images/work-with-me-03.png"
>
  <!-- Hero -->
  <section class="py-10 sm:py-14">
    <div class="container max-w-[1100px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-[68ch]">
        <h1 class="text-4xl sm:text-5xl md:text-[54px] font-medium tracking-[-0.03em] leading-[1.05] text-white/95">
          Get your team using AI properly.
        </h1>
        <p class="mt-5 type-lead text-white/80">
          I run practical, hands-on workshops that teach teams how to use tools like Claude, ChatGPT, and other AI platforms in their actual day-to-day work. Not theory. Real workflows, real tools, real results.
        </p>
        <div class="mt-7">
          <Button href={calLink} text="Book a free 30-minute call →" variant="primary" external />
        </div>
      </div>
    </div>
  </section>

  <div class="h-px bg-white/10"></div>

  <div class="container max-w-[1100px] mx-auto px-4 sm:px-6 lg:px-8">

    <!-- What's Included -->
    <section id="whats-included" class="py-12 sm:py-14 scroll-mt-28">
      <div class="mb-10">
        <div class="text-xs tracking-[0.22em] uppercase text-white/50 mb-3">Workshops</div>
        <h2 class="type-h2 text-white/90">What I offer</h2>
        <p class="mt-3 type-lead text-white/70 max-w-[56ch]">
          Half-day sessions designed for teams who want to work smarter, not harder.
        </p>
      </div>

      <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 sm:p-8">
        <ul class="space-y-4 stagger-children">
          <li class="flex items-start gap-3">
            <span class="text-primary font-semibold shrink-0">Half-day workshops</span>
            <span class="text-white/70">Up to 20 people. Hands-on exercises, not slides.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary font-semibold shrink-0">Custom sessions</span>
            <span class="text-white/70">Tailored to your industry and the tools your team already uses.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary font-semibold shrink-0">Follow-up support</span>
            <span class="text-white/70">Questions after the workshop? I'm available to help.</span>
          </li>
        </ul>
      </div>
    </section>

    <div class="h-px bg-white/10"></div>

    <!-- Who It's For -->
    <section id="audience" class="py-12 sm:py-14 scroll-mt-28">
      <div class="mb-10">
        <div class="text-xs tracking-[0.22em] uppercase text-white/50 mb-3">Audience</div>
        <h2 class="type-h2 text-white/90">Who this is for</h2>
      </div>

      <p class="text-white/75 leading-[1.65] max-w-[56ch]">
        Business owners and team leads who want their people to work smarter and faster using AI, without the overwhelm. If your team has heard about AI but doesn't know where to start, or has tried it and gotten mixed results, these workshops bridge the gap.
      </p>
    </section>

    <div class="h-px bg-white/10"></div>

    <!-- CTA -->
    <section class="pb-14 sm:pb-20">
      <div class="rounded-3xl border border-white/10 bg-[#121212]/70 backdrop-blur-xl p-8 sm:p-10">
        <div class="max-w-[72ch]">
          <h2 class="type-h2 text-white/92">
            Ready to get your team up to speed?
          </h2>
          <p class="mt-3 text-base sm:text-lg leading-[1.65] text-white/80">
            Book a free 30-minute call. Tell me about your team and what you want to achieve. I'll tell you honestly whether these workshops are the right fit.
          </p>
          <div class="mt-6 flex flex-wrap items-center gap-3">
            <Button href={calLink} text="Book a free 30-minute call →" variant="primary" external />
            <span class="text-sm text-white/55">
              Prefer email? <a href={`mailto:${emailAddress}`} class="text-white/80 underline underline-offset-4 decoration-white/25 hover:text-white hover:decoration-white/50 transition-colors">{emailAddress}</a>
            </span>
          </div>
        </div>
      </div>
    </section>

  </div>

  <!-- Footer note -->
  <div class="container max-w-[1100px] mx-auto px-4 sm:px-6 lg:px-8 pb-6">
    <p class="text-xs text-white/40 text-center">
      Based in Cape Town. Available for local and remote workshops.
    </p>
  </div>
</Layout>
